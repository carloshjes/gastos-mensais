rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função principal de validação de dados
    function dadosValidos() {
      let dados = request.resource.data;
      
      // 1. Exige que todos estes campos existam
      let temCampos = dados.keys().hasAll(
        ['tipo', 'descricao', 'categoria', 'valor', 'userId', 'pago', 'dataCriacao']
      );
      
      // 2. Bloqueia qualquer campo extra (Proteção contra hackers)
      let camposPermitidos = dados.keys().hasOnly(
        ['tipo', 'descricao', 'categoria', 'valor', 'userId', 'pago', 'dataCriacao']
      );
      
      // 3. Verifica os tipos de dados
      let tiposCertos = 
        dados.tipo is string &&
        dados.descricao is string &&
        dados.categoria is string &&
        dados.valor is number &&
        dados.userId is string &&
        dados.pago is bool;
        
      let dataValida = dados.dataCriacao is timestamp;
        
      let tipoValido = dados.tipo in ['entrada', 'saida'];
      
      // 4. Aceita apenas as tuas categorias exatas
      let categoriaValida = (
        (dados.tipo == 'saida' && dados.categoria in [
          'Contas Fixas', 'Alimentação', 'Transporte',
          'Educação', 'Saúde', 'Outros'
        ]) ||
        (dados.tipo == 'entrada' && dados.categoria in [
          'Salário', 'Freelance', 'Investimentos', 'Vendas', 'Outros'
        ])
      );
        
      // 5. Impede textos vazios ou gigantes
      let descricaoSegura = dados.descricao.size() > 0
        && dados.descricao.size() <= 100
        && dados.descricao.matches('.*\\S.*');
      
      // 6. Impede valores negativos ou absurdos
      let valorSeguro = dados.valor > 0 && dados.valor <= 9999999.99;
      
      return temCampos && camposPermitidos && tiposCertos 
        && tipoValido && categoriaValida 
        && descricaoSegura && valorSeguro
        && dataValida;
    }

    match /despesas/{despesaId} {
      // Apenas o dono pode ler e apagar
      allow read, delete: if request.auth != null 
        && request.auth.uid == resource.data.userId;
      
      // Apenas o dono pode criar e os dados têm de ser válidos
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId 
        && dadosValidos();
                    
      // Apenas o dono pode atualizar, e os dados têm de ser válidos.
      allow update: if request.auth != null 
        && request.auth.uid == request.resource.data.userId 
        && request.auth.uid == resource.data.userId
        && dadosValidos()
        // PROTEÇÃO FINAL: Garante que o usuário nunca transfira a despesa para outro usuário.
        // A data está liberada para edição!
        && request.resource.data.userId == resource.data.userId;
    }
  }
}
